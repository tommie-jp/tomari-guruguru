# このファイルをコピーして .env.local を作成し、自分の環境に合わせて編集してください。
#   cp .env.local.example .env.local
#
# どちらの変数も任意です。未設定なら開発サーバーはポータブルな既定で動作します:
#   host = 127.0.0.1 / 起動時に talk.html を自動で開く
# WSL2 + Windows Chrome のような構成では、両方 1 を設定するのがおすすめです。

# 1 にすると 0.0.0.0 でリッスンし、WSL の Windows 側 Chrome から
# localhost:5173 で到達できるようになります。
VITE_HOST=1

# 1 にすると自動ブラウザオープンを無効化します。
# （WSL からは Windows の Chrome を直接起動できないため）
VITE_NO_OPEN=1
