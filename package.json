{
  "name": "guruguru-avatar",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "relay": "node server/relay.mjs",
    "build": "vite build",
    "prebuild:local": "node scripts/copy-mediapipe-assets.mjs",
    "build:local": "cross-env VITE_BASE=/ vite build --outDir dist-local",
    "start": "node server/relay.mjs --web-root dist-local",
    "build:relay": "npm run build:relay:win && npm run build:relay:linux && npm run build:relay:macos",
    "build:relay:win": "bun build --compile --minify --target=bun-windows-x64 server/relay.mjs --outfile dist-exe/guruguru-relay.exe",
    "build:relay:linux": "bun build --compile --minify --target=bun-linux-x64 server/relay.mjs --outfile dist-exe/guruguru-relay-linux-x64",
    "build:relay:macos": "bun build --compile --minify --target=bun-darwin-arm64 server/relay.mjs --outfile dist-exe/guruguru-relay-macos-arm64",
    "preview": "vite preview --base /guruguru-avatar/",
    "verify:pages": "node scripts/verify-pages-build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:mediapipe": "node scripts/copy-mediapipe-assets.mjs",
    "predev": "node scripts/copy-mediapipe-assets.mjs",
    "prebuild": "node scripts/copy-mediapipe-assets.mjs"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "pixi.js": "^8.19.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
